    {
      "parameters": {
        "promptType": "define",
        "text": "=Return ONLY valid JSON.\n\n{\n\"summary\": \"short meeting summary\",\n\"tasks\": [\n{\n\"task\": \"task name\",\n\"owner\": \"person responsible\",\n\"deadline\": \"YYYY-MM-DD\",\n\"priority\": \"High\"\n}\n]\n}\n\nRules:\n\n* No markdown\n* No explanation\n* No code block\n* No extra text\n* Priority must be High, Medium, or Low\n* If no deadline exists use \"TBD\"\n\nTranscript:\n{{ $json.text }}\n",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1248,
        96
      ],
      "id": "8dad4fc3-60ee-45cf-b724-4e4de21ec2df",
      "name": "Generate Summary & Action Items"
    },
    {
      "parameters": {
        "functionCode": "const raw = items[0].json.output || '';\n\ntry {\n\n  const parsed = JSON.parse(raw);\n\n  return [{\n    json: parsed\n  }];\n\n} catch (e) {\n\n  return [{\n    json: {\n      summary: \"AI parsing failed\",\n      tasks: []\n    }\n  }];\n\n}"
      },
      "id": "171df39a-3dda-4849-9585-78094f591761",
      "name": "Parse Meeting Insights",
      "type": "n8n-nodes-base.function",
      "position": [
        1616,
        96
      ],
      "typeVersion": 1
    },
    {
      "parameters": {
        "functionCode": "if (!items[0].json.tasks || items[0].json.tasks.length === 0) {\n  return [];\n}\n\nreturn items[0].json.tasks\n  .filter(task =>\n    task.task &&\n    task.task.trim() !== ''\n  )\n  .map(task => ({\n    json: {\n      task: task.task || '',\n      owner: task.owner || 'Unassigned',\n      deadline: task.deadline || 'TBD',\n      priority: task.priority || 'Medium'\n    }\n  }));"
      },
      "id": "61a71029-ebee-45b5-b0a3-15cc85d4fcd5",
      "name": "Extract Action Items",
      "type": "n8n-nodes-base.function",
