      "parameters": {
        "promptType": "define",
        "text": "=Return ONLY valid JSON.\n\n{\n\"summary\": \"short meeting summary\",\n\"tasks\": [\n{\n\"task\": \"task name\",\n\"owner\": \"person responsible\",\n\"deadline\": \"YYYY-MM-DD\",\n\"priority\": \"High\"\n}\n]\n}\n\nRules:\n\n* No markdown\n* No explanation\n* No code block\n* No extra text\n* Priority must be High, Medium, or Low\n* If no deadline exists use \"TBD\"\n\nTranscript:\n{{ $json.text }}\n",
        "options": {}
