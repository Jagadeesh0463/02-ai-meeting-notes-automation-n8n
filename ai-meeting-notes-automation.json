{
  "name": "Meeting Notes Automation",
  "nodes": [
    {
      "parameters": {
        "functionCode": "const raw = items[0].json.output || '';\n\ntry {\n\n  const parsed = JSON.parse(raw);\n\n  return [{\n    json: parsed\n  }];\n\n} catch (e) {\n\n  return [{\n    json: {\n      summary: \"AI parsing failed\",\n      tasks: []\n    }\n  }];\n\n}"
      },
      "id": "171df39a-3dda-4849-9585-78094f591761",
      "name": "Parse AI Output",
      "type": "n8n-nodes-base.function",
      "position": [
        1376,
        96
      ],
      "typeVersion": 1
    },
    {
      "parameters": {
        "functionCode": "if (!items[0].json.tasks || items[0].json.tasks.length === 0) {\n  return [];\n}\n\nreturn items[0].json.tasks\n  .filter(task =>\n    task.task &&\n    task.task.trim() !== ''\n  )\n  .map(task => ({\n    json: {\n      task: task.task || '',\n      owner: task.owner || 'Unassigned',\n      deadline: task.deadline || 'TBD',\n      priority: task.priority || 'Medium'\n    }\n  }));"
      },
