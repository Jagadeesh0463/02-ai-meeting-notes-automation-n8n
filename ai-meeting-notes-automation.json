    {
      "parameters": {
        "sendTo": "{{YOUR_EMAIL}}",
        "subject": "Meeting Recap & Action Items",
        "message": "=<h2>Meeting Summary</h2>\n\n<p>{{$json[\"summary\"]}}</p>\n\n<hr>\n\n<h2>Action Items</h2>\n\n<ul>\n{{\n$json[\"tasks\"].map(t =>\n\"<li><b>\" + t.task + \"</b><br>\" +\n\"Owner: \" + t.owner + \"<br>\" +\n\"Deadline: \" + (t.deadline || \"TBD\") + \"<br>\" +\n\"Priority: \" + (t.priority || \"Medium\") +\n\"</li><br>\"\n).join(\"\")\n}}\n</ul>\n\n<hr>\n\n<p><i>Generated automatically using AI meeting automation.</i></p>",
        "options": {
          "appendAttribution": false
